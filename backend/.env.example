# Server
PORT=8080
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://kgolf:kgolf_password@localhost:5432/kgolf_app

# Email (Gmail with App-Specific Password)
# Go to https://myaccount.google.com/security
# Enable 2-Step Verification → Generate App Password
# Use the 16-character password (with spaces)
GMAIL_USER=general@konegolf.ca
GMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_FROM=K one Golf <general@konegolf.ca>

# Frontend origin used in links sent via email
FRONTEND_ORIGIN=http://localhost:5173

# Seeding (optional; defaults create 4 rooms)
SEED_ADMIN_EMAIL=admin@konegolf.ca
# Seed a test user only in non-production, or set SEED_ENABLE_TEST_USER=true to force in prod/staging
# SEED_ENABLE_TEST_USER=true
SEED_TEST_EMAIL=test@example.com
SEED_TEST_NAME=Test User
SEED_TEST_PASSWORD=password123